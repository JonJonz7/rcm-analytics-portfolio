# RCM Analytics Demo — example environment file. Copy to .env and fill in.
# Both variables are optional; the app runs with neither set.

# Postgres connection string. When unset, the app generates synthetic data
# in memory. To use a database, run db/schema.sql then db/seed_synthetic.sql.
DATABASE_URL=

# Shared demo password. When unset, the login gate is disabled.
DEMO_PASSWORD=
